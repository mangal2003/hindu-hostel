<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <main class="min-h-screen flex items-center justify-center bg-zinc-950 p-6 font-serif">
                <div class="bg-zinc-900 w-full max-w-md rounded-2xl shadow-2xl border border-zinc-800 overflow-hidden">
                    <div class="h-1.5 bg-red-700 w-full"></div>

                    <div class="p-10 text-center">
                        <div
                            class="w-20 h-20 bg-zinc-950 border border-zinc-800 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="ri-lock-unlock-line text-zinc-500 text-3xl"></i>
                        </div>

                        <h2 class="text-3xl text-white font-bold">Recover Access</h2>
                        <p
                            class="text-yellow-500 text-[10px] uppercase tracking-[0.2em] mt-3 font-sans font-bold leading-relaxed">
                            Enter your registered email address to receive a secure reset token via email
                        </p>
                    </div>

                    <form action="/forgot-password" method="POST" class="px-10 pb-10 space-y-6 font-sans">
                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-600 mb-2 tracking-widest">Email
                                Address</label>
                            <div class="relative">
                                <i class="ri-mail-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400"></i>
                                <input type="email" name="email" required
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 pl-12 pr-4 text-white placeholder:text-zinc-500 focus:outline-none focus:border-red-700 transition-all duration-300"
                                    placeholder="yourname@example.com">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-red-700 text-white font-bold py-5 rounded-xl hover:bg-white hover:text-black transition-all duration-500 shadow-xl tracking-[0.3em] text-[10px] uppercase">
                            Send Reset Link
                        </button>

                        <div class="text-center pt-4">
                            <a href="/login"
                                class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors font-bold">
                                <i class="ri-arrow-left-s-line"></i> Return to Login
                            </a>
                        </div>
                    </form>
                </div>
            </main>

            <%- include('partials/footer') %>