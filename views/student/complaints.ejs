<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>

            <main class="min-h-screen bg-stone-950 p-6 md:p-12 text-white font-sans">
                <div class="max-w-6xl mx-auto">

                    <header class="relative mb-12 animate-in fade-in slide-in-from-top-4 duration-700">
                        <div class="border-l-4 border-red-700 pl-6 flex justify-between items-end flex-wrap">
                            <div>
                                <h2 class="text-4xl font-serif mb-2 italic">Complaint Portal</h2>
                                <p class="text-zinc-500 uppercase tracking-[0.3em] text-[10px] font-bold">Formal Issue
                                    Registration & Tracking</p>
                            </div>
                            <a href="javascript:void(0)" onclick="history.back()"
                                class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 m-6">
                                <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                                <span>Back</span>
                            </a>
                        </div>
                    </header>

                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

                        <div class="lg:col-span-4">
                            <div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl shadow-2xl sticky top-8">
                                <h3 class="text-lg font-bold mb-8 flex items-center gap-3 text-zinc-200">
                                    <i class="ri-edit-line text-red-600 text-xl"></i> New Complaint
                                </h3>

                                <form action="/student/complaints/new" method="POST" class="space-y-6">
                                    <div class="group">
                                        <label
                                            class="block text-[10px] font-bold text-zinc-500 mb-2 uppercase tracking-widest group-focus-within:text-red-600 transition-colors">Category</label>
                                        <select name="category" required
                                            class="w-full bg-stone-950 border border-zinc-800 rounded-xl p-4 text-sm text-zinc-300 focus:border-red-700 outline-none transition-all appearance-none cursor-pointer">
                                            <option value="Electricity">Electricity & Power</option>
                                            <option value="Cleaning">Sanitation & Cleaning</option>
                                            <option value="Plumbing">Water & Plumbing</option>
                                            <option value="Other">Miscellaneous</option>
                                        </select>
                                    </div>

                                    <div class="group">
                                        <label
                                            class="block text-[10px] font-bold text-zinc-500 mb-2 uppercase tracking-widest group-focus-within:text-red-600 transition-colors">Subject</label>
                                        <input type="text" name="subject" placeholder="Summary of the issue..." required
                                            class="w-full bg-stone-950 border border-zinc-800 rounded-xl p-4 text-sm text-white focus:border-red-700 outline-none transition-all placeholder:text-zinc-700">
                                    </div>

                                    <div class="group">
                                        <label
                                            class="block text-[10px] font-bold text-zinc-500 mb-2 uppercase tracking-widest group-focus-within:text-red-600 transition-colors">Detailed
                                            Description</label>
                                        <textarea name="description" rows="5" style="resize:none;"
                                            placeholder="Please explain the problem in detail..." required
                                            class="w-full bg-stone-950 border border-zinc-800 rounded-xl p-4 text-sm text-white focus:border-red-700 outline-none transition-all placeholder:text-zinc-700"></textarea>
                                    </div>

                                    <button type="submit"
                                        class="w-full bg-red-700 hover:bg-red-600 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-red-900/20 tracking-[0.2em] text-[10px] uppercase">
                                        Submit Complaint
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="lg:col-span-8">
                            <h3 class="text-lg font-bold mb-8 flex items-center gap-3 text-zinc-200">
                                <i class="ri-history-line text-red-600 text-xl"></i> Complaint History
                            </h3>

                            <div class="space-y-6">
                                <% if(complaints.length> 0) { %>
                                    <% complaints.forEach(c=> { %>
                                        <div
                                            class="bg-zinc-900/30 border border-zinc-900 p-6 rounded-2xl flex flex-col md:flex-row md:justify-between md:items-start gap-6 group hover:bg-zinc-900/50 hover:border-zinc-800 transition-all duration-300">

                                            <div class="flex-grow space-y-3">
                                                <div class="flex flex-wrap items-center gap-3">
                                                    <span
                                                        class="text-[9px] font-black px-2.5 py-1 rounded bg-zinc-950 text-zinc-500 border border-zinc-800 uppercase tracking-widest">
                                                        <%= c.category %>
                                                    </span>
                                                    <span
                                                        class="text-[9px] font-mono text-zinc-600 uppercase tracking-widest">
                                                        Record ID: <%= c._id.toString().slice(-6).toUpperCase() %>
                                                    </span>
                                                </div>

                                                <h5
                                                    class="font-bold text-xl text-zinc-100 group-hover:text-white transition-colors">
                                                    <%= c.subject %>
                                                </h5>

                                                <p class="text-zinc-500 text-sm leading-relaxed max-w-xl italic">
                                                    "<%= c.description %>"
                                                </p>

                                                <div class="flex items-center gap-2 pt-2">
                                                    <i class="ri-time-line text-zinc-700 text-xs"></i>
                                                    <span
                                                        class="text-[10px] text-zinc-600 font-bold uppercase tracking-widest">
                                                        Registered on <%= c.createdAt.toLocaleDateString('en-GB', {
                                                            day: '2-digit' , month: 'short' , year: 'numeric' }) %>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="flex-shrink-0 flex flex-col items-end gap-3">
                                                <span class="px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-[0.2em] whitespace-nowrap inline-block min-w-[120px] text-center
                                        <%= c.status === 'Pending' ? 'bg-amber-500/10 text-amber-500 border border-amber-500/20' : 
                                           c.status === 'In Progress' ? 'bg-blue-500/10 text-blue-500 border border-blue-500/20' : 
                                           'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' %>">
                                                    <%= c.status %>
                                                </span>

                                                <% if (c.status==='Resolved' ) { %>
                                                    <i class="ri-checkbox-circle-fill text-emerald-500/30 text-2xl"></i>
                                                    <% } %>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div
                                                    class="flex flex-col items-center justify-center py-32 border-2 border-dashed border-zinc-700 rounded-3xl">
                                                    <i class="ri-shield-check-line text-6xl text-zinc-400 mb-4"></i>
                                                    <p
                                                        class="text-zinc-500 font-sans text-[10px] font-bold uppercase tracking-[0.3em]">
                                                        No Active Complaints</p>
                                                    <p class="text-zinc-700 text-[10px] mt-2 italic">No issues have been
                                                        registered under your account.</p>
                                                </div>
                                                <% } %>
                            </div>
                        </div>

                    </div>
                </div>
            </main>

            <%- include('../partials/footer') %>