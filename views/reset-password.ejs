<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <main class="min-h-screen flex items-center justify-center bg-zinc-950 p-6 font-serif">
                <div class="bg-zinc-900 w-full max-w-md rounded-2xl shadow-2xl border border-zinc-800 overflow-hidden">
                    <div class="h-1.5 bg-red-700 w-full"></div>

                    <div class="p-10 text-center">
                        <div
                            class="w-20 h-20 bg-red-900/10 border border-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="ri-shield-keyhole-line text-red-600 text-3xl"></i>
                        </div>

                        <h2 class="text-3xl text-white font-bold tracking-tighter">New Credentials</h2>
                        <p
                            class="text-zinc-500 text-[10px] uppercase tracking-[0.2em] mt-3 font-sans font-bold leading-relaxed">
                            Tokens validated. Please establish your new private access key below.
                        </p>
                    </div>

                    <form action="/reset-password/<%= token %>" method="POST" class="px-10 pb-10 space-y-6 font-sans">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-zinc-600 mb-2 tracking-widest">New
                                Password</label>
                            <input type="password" name="password" required minlength="8"
                                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 px-4 text-white focus:outline-none focus:border-red-700 transition-all duration-300"
                                placeholder="Min. 8 characters">
                        </div>

                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-600 mb-2 tracking-widest">Confirm
                                Password</label>
                            <input type="password" name="confirmPassword" required
                                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 px-4 text-white focus:outline-none focus:border-red-700 transition-all duration-300"
                                placeholder="Repeat password">
                        </div>

                        <button type="submit"
                            class="w-full bg-red-700 text-white font-bold py-5 rounded-xl hover:bg-white hover:text-black transition-all duration-500 shadow-xl tracking-[0.3em] text-[10px] uppercase">
                            Update Password
                        </button>
                    </form>
                </div>
            </main>

            <%- include('partials/footer') %>