<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <main class="min-h-screen flex items-center justify-center bg-zinc-950 p-6 font-serif">
                <div class="bg-zinc-900 w-full max-w-md rounded-2xl shadow-2xl overflow-hidden border border-zinc-800">

                    <div class="h-2 bg-red-700 w-full"></div>

                    <div class="p-10 pb-0 text-center">
                        <div
                            class="w-20 h-20 bg-emerald-900/20 border border-emerald-800/50 rounded-full flex items-center justify-center mx-auto mb-6 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
                            <i class="ri-shield-check-line text-emerald-500 text-4xl"></i>
                        </div>

                        <h2 class="text-3xl text-white font-bold">Email Verified</h2>
                        <p
                            class="text-zinc-500 text-[10px] uppercase tracking-[0.2em] mt-3 font-sans font-bold leading-relaxed">
                            Identity Confirmed. Finalize your credentials to activate your resident access.
                        </p>
                    </div>

                    <form action="/activate-account" method="POST" class="p-10 space-y-6 font-sans">
                        <input type="hidden" name="token" value="<%= token %>">

                        <div>
                            <label class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Set
                                New Password</label>
                            <div class="relative">
                                <i class="ri-key-2-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500"></i>
                                <input type="password" name="password" required minlength="8"
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 pl-12 pr-4 text-white placeholder:text-zinc-500 focus:outline-none focus:border-red-700 transition-all duration-300"
                                    placeholder="Min. 8 characters">
                            </div>
                        </div>

                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Confirm
                                Password</label>
                            <div class="relative">
                                <i
                                    class="ri-checkbox-circle-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500"></i>
                                <input type="password" name="confirmPassword" required
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 pl-12 pr-4 text-white placeholder:text-zinc-500 focus:outline-none focus:border-red-700 transition-all duration-300"
                                    placeholder="Re-type password">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-red-700 text-white font-bold py-5 rounded-xl hover:bg-white hover:text-black transition-all duration-500 flex items-center justify-center gap-2 shadow-xl shadow-red-950/20 tracking-[0.3em] text-[10px] uppercase">
                            Activate Account
                        </button>
                    </form>

                    <div class="bg-zinc-950/50 p-6 text-center border-t border-zinc-800">
                        <p
                            class="text-zinc-400 text-[10px] uppercase tracking-widest flex items-center justify-center gap-2">
                            <i class="ri-ancient-gate-line text-xs"></i> Hindu Hostel, Prayagraj
                        </p>
                    </div>
                </div>
            </main>

            <%- include('partials/footer') %>