<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

            <main class="min-h-screen bg-zinc-950 text-stone-50 pb-20 font-serif">
                <div class="max-w-5xl mx-auto px-6 pt-10">

                    <% if (locals.user && (user.role==='warden' || user.role==='admin' ) ) { %>
                        <div
                            class="mb-16 p-6 border-2 border-dashed border-red-600 rounded-xl bg-zinc-800 flex justify-between items-center gap-6 flex-wrap group">
                            <div>
                                <h4 class="text-white font-sans font-bold">Event Management</h4>
                                <p class="text-zinc-400 text-xs font-sans">Update the hostel history with new events.
                                </p>
                            </div>
                            <a href="/admin/events/new"
                                class="bg-red-700 hover:bg-white hover:text-black text-white px-6 py-2 rounded font-sans font-bold text-[10px] tracking-widest transition-all uppercase">
                                ADD NEW EVENT
                            </a>
                        </div>
                        <% } %>
                            <a href="/"
                                class="text-zinc-500 hover:text-red-600 transition-all text-[12px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 m-6">
                                <i class="ri-arrow-left-line"></i> Back
                            </a>
                            <h2 class="text-3xl mb-12 border-b-2 border-zinc-600 inline-block pb-2 tracking-tighter">
                                Chronicles <span
                                    class="text-red-500 font-sans font-bold text-sm align-middle ml-2 tracking-widest uppercase whitespace-nowrap">of
                                    Hindu Hostel</span>
                            </h2>

                            <div class="space-y-32">
                                <% if (typeof events !=='undefined' && events.length> 0) { %>
                                    <% events.forEach(event=> { %>
                                        <section
                                            class="max-w-3xl mx-auto group bg-zinc-900 rounded-lg border border-zinc-600 shadow-xl p-4">
                                            <h3 class="text-3xl font-bold mb-4 text-white tracking-tight">
                                                <%= event.title %>
                                            </h3>
                                            <div
                                                class="bg-zinc-900 rounded-lg overflow-hidden border border-zinc-800 shadow-2xl relative">
                                                <div class="swiper mySwiper-<%= event._id %> h-[250px] md:h-[350px]">
                                                    <div class="swiper-wrapper">
                                                        <% event.images.forEach(img=> { %>
                                                            <div class="swiper-slide">
                                                                <img src="<%= img %>"
                                                                    class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-1000">
                                                            </div>
                                                            <% }) %>
                                                    </div>
                                                    <div class="swiper-pagination"></div>
                                                    <div class="swiper-button-next !text-white !scale-50"></div>
                                                    <div class="swiper-button-prev !text-white !scale-50"></div>
                                                </div>
                                            </div>

                                            <div class="mt-6">

                                                <p
                                                    class="text-zinc-400 font-sans text-base leading-relaxed italic max-w-4xl">
                                                    <%= event.description %>
                                                </p>
                                            </div>
                                            <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                                                <div class="flex gap-6 mb-4">
                                                    <a href="/admin/events/edit/<%= event._id %>"
                                                        class="text-[12px] font-sans font-bold text-blue-500 hover:text-white flex items-center gap-1 uppercase tracking-widest">
                                                        <i class="ri-edit-box-line"></i> Edit
                                                    </a>
                                                    <form action="/admin/events/delete/<%= event._id %>" method="POST"
                                                        onsubmit="return confirm('Archive this memory forever?')">
                                                        <button
                                                            class="text-[12px] font-sans font-bold text-red-500 hover:text-red-700 flex items-center gap-1 uppercase tracking-widest">
                                                            <i class="ri-delete-bin-line"></i> Remove
                                                        </button>
                                                    </form>
                                                </div>
                                                <% } %>

                                                    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
                                                        <% if(event.chiefGuests && event.chiefGuests.length> 0) { %>
                                                            <div
                                                                class="bg-yellow-900/40 p-3 border-l-4 border-yellow-700 rounded-r-lg">
                                                                <p
                                                                    class="text-[10px] uppercase text-yellow-500 mb-3 font-sans font-bold tracking-[0.2em]">
                                                                    Chief Guests</p>
                                                                <ul class="text-sm space-y-2 text-zinc-300 font-sans">
                                                                    <% event.chiefGuests.forEach(cg=> { %>
                                                                        <li class="flex items-center gap-2 font-bold"><i
                                                                                class="ri-user-star-line text-yellow-500"></i>
                                                                            <%= cg %>
                                                                        </li>
                                                                        <% }) %>
                                                                </ul>
                                                            </div>
                                                            <% } %>

                                                                <% if(event.winners && event.winners.length> 0) { %>
                                                                    <div
                                                                        class="bg-emerald-900/40 p-3 border-l-4 border-emerald-800 rounded-r-lg">
                                                                        <p
                                                                            class="text-[10px] uppercase text-emerald-600 mb-3 font-sans font-bold tracking-[0.2em]">
                                                                            Winners</p>
                                                                        <ul
                                                                            class="text-sm space-y-2 text-zinc-200 font-sans">
                                                                            <% event.winners.forEach(w=> { %>
                                                                                <li
                                                                                    class="flex items-center gap-2 font-bold">
                                                                                    <i
                                                                                        class="ri-medal-line text-emerald-600"></i>
                                                                                    <%= w %>
                                                                                </li>
                                                                                <% }) %>
                                                                        </ul>
                                                                    </div>
                                                                    <% } %>
                                                    </div>
                                        </section>
                                        <% }) %>
                                            <% } else { %>
                                                <div
                                                    class="py-24 text-center border-2 border-dashed border-zinc-600 rounded-3xl">
                                                    <i class="ri-history-line text-5xl text-zinc-400 mb-4 block"></i>
                                                    <p
                                                        class="text-zinc-400 italic font-sans uppercase text-[10px] tracking-[0.3em]">
                                                        Nothing to see here!
                                                    </p>
                                                </div>
                                                <% } %>
                            </div>
                </div>
            </main>

            <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
        <% if (typeof events !== 'undefined' && events.length > 0) { %>
            <% events.forEach(event => { %>
                    new Swiper(".mySwiper-<%= event._id %>", {
                        loop: true,
                        speed: 1200,
                        autoplay: {
                            delay: 4000,
                            disableOnInteraction: false,
                        },
                        effect: "fade",
                        fadeEffect: {
                            crossFade: true
                        },
                        watchSlidesProgress: true,
                        observer: true,
                        observeParents: true,

                        pagination: {
                            el: ".swiper-pagination",
                            clickable: true,
                            dynamicBullets: true
                        },
                        navigation: {
                            nextEl: ".swiper-button-next",
                            prevEl: ".swiper-button-prev"
                        },
                    });
            <% }) %>
        <% } %>
    });
            </script>

            <%- include('partials/footer') %>