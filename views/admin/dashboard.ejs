<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>
            <div id="adminModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
                <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="toggleAdminModal()"></div>

                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden font-sans">
                    <div class="p-6 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                        <h3 class="text-white font-serif italic text-xl">Authority Register</h3>
                        <button onclick="toggleAdminModal()" class="text-zinc-500 hover:text-white transition-colors">
                            <i class="ri-close-line text-2xl"></i>
                        </button>
                    </div>

                    <div class="max-h-[60vh] overflow-y-auto p-4 space-y-3">
                        <% allAdmins.forEach(adm=> { %>
                            <div
                                class="flex items-center justify-between p-4 bg-zinc-950 border border-zinc-800 rounded-xl">
                                <div>
                                    <p class="text-emerald-500 font-bold text-sm">
                                        <%= adm.name %>
                                    </p>
                                    <p class="text-zinc-300 text-[10px] tracking-widest uppercase">
                                        <%= adm.role %>
                                    </p>
                                </div>

                                <form action="/admin/update-role" method="POST" class="flex gap-2">
                                    <input type="hidden" name="adminId" value="<%= adm._id %>">
                                    <select name="newRole" onchange="this.form.submit()"
                                        class="bg-blue-900 border border-blue-600 text-white text-[10px] font-bold uppercase py-1 px-3 rounded-lg focus:border-blue-500 outline-none">
                                        <option value="admin" <%=adm.role==='admin' ? 'selected' : '' %>>Admin
                                        </option>
                                        <option value="warden" <%=adm.role==='warden' ? 'selected' : '' %>>Warden
                                        </option>
                                    </select>
                                </form>
                            </div>
                            <% }) %>
                    </div>

                    <div class="p-4 bg-zinc-950/50 text-center">
                        <p class="text-[10px] text-zinc-400 uppercase tracking-widest">Digital Authorization Required
                            for
                            Changes</p>
                    </div>
                </div>
            </div>
            <div id="residentModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
                <div class="absolute inset-0 bg-black/85 backdrop-blur-md" onclick="toggleResidentModal()"></div>

                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-4xl rounded-2xl shadow-2xl overflow-hidden font-sans">
                    <div
                        class="p-6 border-b border-zinc-800 bg-zinc-950/50 flex flex-col md:flex-row justify-between items-center gap-4">
                        <h3 class="text-white font-serif italic text-xl">Resident Directory</h3>
                        <div class="relative w-full md:w-64">
                            <i class="ri-search-line absolute left-3 top-1.5 text-zinc-500"></i>
                            <input type="text" id="residentSearch" onkeyup="filterResidents()"
                                placeholder="Search Name or Room..."
                                class="w-full bg-zinc-900 border border-zinc-800 rounded-lg py-2 pl-10 pr-4 text-xs text-white outline-none focus:border-red-700">
                        </div>
                    </div>

                    <div class="max-h-[60vh] overflow-y-auto p-4">
                        <table class="w-full text-left border-collapse" id="residentTable">
                            <thead class="bg-zinc-950 text-zinc-300 text-[10px] uppercase tracking-widest font-bold">
                                <tr>
                                    <th class="p-4">Student Details</th>
                                    <th class="p-4">Enrollment</th>
                                    <th class="p-4">Room</th>
                                    <th class="p-4 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="text-xs">
                                <% allStudents.forEach(st=> { %>
                                    <tr
                                        class="border-b border-zinc-800/50 hover:bg-zinc-800/30 transition-colors resident-row">
                                        <td class="p-4">
                                            <p class="text-white font-bold">
                                                <%= st.name %>
                                            </p>
                                            <p class="text-zinc-300 text-[12px]">
                                                <%= st.email %>
                                            </p>
                                        </td>
                                        <td class="p-4 font-mono text-zinc-400">
                                            <%= st.enrollmentNumber %>
                                        </td>
                                        <td class="p-4 text-red-500 font-bold">
                                            <%= st.roomNumber %>
                                        </td>
                                        <td class="p-4 text-right">
                                            <form action="/admin/remove-resident/<%= st._id %>" method="POST"
                                                onsubmit="return confirm('Expel this resident from the digital registry?')">
                                                <button class="text-zinc-600 hover:text-red-600 transition-colors">
                                                    <i class="ri-user-unfollow-line text-lg"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 bg-zinc-950 text-center">
                        <p class="text-[9px] text-red-600 uppercase tracking-widest font-bold">End of Directory</p>
                    </div>
                </div>
            </div>
            <div id="securityModal" class="fixed inset-0 z-[110] hidden flex items-center justify-center p-4">
                <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="toggleSecurityModal()"></div>

                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-md rounded-2xl shadow-2xl overflow-hidden font-sans">
                    <div class="p-6 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                        <h3 class="text-white font-serif italic text-xl">Security Desk</h3>
                        <button onclick="toggleSecurityModal()" class="text-zinc-500 hover:text-white">
                            <i class="ri-close-line text-2xl"></i>
                        </button>
                    </div>

                    <div class="p-8">
                        <form action="/admin/change-password" method="POST" class="space-y-4">
                            <div>
                                <label
                                    class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Current
                                    Password</label>
                                <input type="password" name="currentPassword" required
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-emerald-600 outline-none transition-all">
                            </div>
                            <div>
                                <label
                                    class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">New
                                    Password</label>
                                <input type="password" name="newPassword" required minlength="8"
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-lg py-3 px-4 text-white focus:border-emerald-600 outline-none transition-all">
                            </div>
                            <button type="submit"
                                class="w-full bg-emerald-700 text-white font-bold py-3 rounded-lg hover:bg-white hover:text-black transition-all text-xs tracking-widest uppercase">
                                Update Password
                            </button>
                        </form>

                        <div class="relative my-8">
                            <div class="absolute inset-0 flex items-center"><span
                                    class="w-full border-t border-zinc-800"></span>
                            </div>
                            <div class="relative flex justify-center text-[10px] uppercase"><span
                                    class="bg-zinc-900 px-2 text-zinc-600 tracking-tighter">Or secure reset</span></div>
                        </div>

                        <form action="/forgot-password" method="POST">
                            <input type="hidden" name="email" value="<%= user.email %>">
                            <button type="submit"
                                class="w-full border border-zinc-800 text-zinc-400 py-3 rounded-lg hover:bg-zinc-800 transition-all text-[10px] font-bold tracking-widest uppercase flex items-center justify-center gap-2">
                                <i class="ri-mail-send-line"></i> Send Reset Link to Email
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div id="announcementModal"
                class="fixed inset-0 top-16 z-[120] hidden flex items-center justify-center p-4">
                <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="toggleAnnouncementModal()"></div>

                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden font-sans">
                    <div class="p-4 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                        <h3 class="text-white font-serif italic text-xl">New Broadcast</h3>
                        <button onclick="toggleAnnouncementModal()" class="text-zinc-500 hover:text-white">
                            <i class="ri-close-line text-2xl"></i>
                        </button>
                    </div>

                    <form action="/admin/announcements/new" method="POST" class="p-8 space-y-6">
                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Notice
                                Category</label>
                            <select name="category"
                                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-3 px-4 text-white focus:border-blue-600 outline-none transition-all">
                                <option value="Hostel">Hostel (Internal)</option>
                                <option value="College">College (Institutional)</option>
                            </select>
                        </div>

                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Update
                                Content</label>
                            <textarea name="content" required rows="4" maxlength="200" style="resize: none;"
                                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 px-4 text-white placeholder:text-zinc-400 focus:border-blue-600 outline-none transition-all"
                                placeholder="E.g. Semester fee submission deadline is April 25..."></textarea>
                        </div>

                        <div>
                            <label
                                class="block text-[10px] font-bold uppercase text-zinc-500 mb-2 tracking-widest">Action
                                Link
                                (Optional)</label>
                            <div class="relative">
                                <i class="ri-link absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400"></i>
                                <input type="url" name="link"
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-3 pl-12 pr-4 text-white placeholder:text-zinc-400 focus:border-blue-600 outline-none transition-all"
                                    placeholder="https://portal.com">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-blue-700 text-white font-bold py-4 rounded-xl hover:bg-white hover:text-black transition-all duration-500 text-[10px] uppercase tracking-[0.3em]">
                            Post to Bulletin
                        </button>
                    </form>
                </div>
            </div>

            <main class="flex-grow bg-zinc-950 p-4 md:p-10 text-stone-50 font-serif">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-10 gap-6">
                    <div>
                        <h2 class="text-3xl md:text-5xl tracking-tighter text-white">Admin's Desk</h2>
                        <p class="text-red-600 font-bold tracking-[0.3em] text-[10px] uppercase mt-2 font-sans">
                            Administrative Control Portal
                        </p>
                    </div>
                    <div class="flex flex-row gap-3 w-full lg:w-auto font-sans">
                        <a href="/admin/register-student"
                            class="flex-1 lg:flex-none bg-red-700 text-white px-4 md:px-6 py-3 rounded shadow-lg hover:bg-white hover:text-black transition-all flex items-center justify-center gap-2 font-bold text-xs">
                            <i class="ri-user-add-line"></i> <span class="hidden sm:inline">REGISTER STUDENT</span><span
                                class="sm:hidden">REGISTER</span>
                        </a>
                        <button
                            class="flex-1 lg:flex-none bg-zinc-900 border border-zinc-800 px-4 md:px-6 py-3 rounded shadow-sm hover:bg-zinc-800 transition flex items-center justify-center gap-2 font-bold text-xs text-zinc-700 cursor-not-allowed">
                            <i class="ri-file-list-3-line"></i> EXPORT
                        </button>
                    </div>
                </div>
                <a href="/"
                    class="text-zinc-500 hover:text-red-600 transition-all text-[12px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 m-6">
                    <i class="ri-arrow-left-line"></i> Back
                </a>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-12 font-sans">
                    <div
                        class="bg-zinc-900 p-5 md:p-7 border-b-4 border-red-700 rounded-t-lg shadow-2xl flex flex-col justify-between">
                        <div>
                            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Residents</p>
                            <h3 class="text-3xl md:text-4xl font-bold mt-2 text-white">
                                <%= studentCount %>
                            </h3>
                        </div>
                        <button onclick="toggleResidentModal()"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-red-700 hover:border-red-700 transition-all text-center flex items-center justify-center gap-2">
                            <i class="ri-group-line"></i> MANAGE RESIDENTS
                        </button>
                    </div>
                    <div class="bg-zinc-900 p-5 md:p-7 border-b-4 border-red-700 rounded-t-lg shadow-2xl">
                        <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Active Complaints</p>
                        <h3 class="text-3xl md:text-4xl font-bold mt-2 text-red-600">
                            <%= pendingCount %>
                        </h3>
                        <a href="/admin/complaints"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-red-700 hover:border-red-700 transition-all text-center flex items-center justify-center gap-2">
                            <p>View All</p>
                        </a>
                    </div>
                    <div class="bg-zinc-900 p-5 md:p-7 border-b-4 border-red-700 rounded-t-lg shadow-2xl">
                        <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Admins</p>
                        <h3 class="text-3xl md:text-4xl font-bold mt-2 text-white">
                            <%= adminsCount %>
                        </h3>
                        <a href="/admin/manage-admins"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-red-700 hover:border-red-700 transition-all text-center flex items-center justify-center gap-2">
                            <p>Manage Access</p>
                        </a>
                    </div>
                    <div
                        class="bg-zinc-900 p-5 md:p-7 border-b-4 border-yellow-500 rounded-t-lg shadow-2xl flex flex-col justify-between">
                        <div>
                            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Authority</p>
                            <h3 class="text-xl md:text-2xl font-bold mt-2 text-zinc-400">Staff Roles</h3>
                        </div>
                        <button onclick="toggleAdminModal()"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-yellow-500 hover:border-yellow-700 transition-all text-center flex items-center justify-center gap-2">
                            <i class="ri-shield-flash-line text-[0.6rem]"></i> MODIFY ACCESS
                        </button>
                    </div>
                    <div
                        class="bg-zinc-900 p-5 md:p-7 border-b-4 border-emerald-600 rounded-t-lg shadow-2xl flex flex-col justify-between">
                        <div>
                            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Security</p>
                            <h3 class="text-xl md:text-2xl font-bold mt-2 text-zinc-400">Account</h3>
                        </div>
                        <button onclick="toggleSecurityModal()"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-emerald-700 hover:border-emerald-700 transition-all text-center flex items-center justify-center gap-2">
                            <i class="ri-lock-password-line"></i> PASSWORD SETTINGS
                        </button>
                    </div>
                    <div
                        class="bg-zinc-900 p-5 md:p-7 border-b-4 border-blue-600 rounded-t-lg shadow-2xl flex flex-col justify-between">
                        <div>
                            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Broadcast</p>
                            <h3 class="text-[1em] md:text-2xl font-bold mt-2 text-zinc-400">Announcements
                            </h3>
                        </div>
                        <button onclick="toggleAnnouncementModal()"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-blue-700 hover:border-blue-700 transition-all text-center flex items-center justify-center gap-2">
                            <i class="ri-megaphone-line"></i> POST UPDATE
                        </button>
                    </div>
                    <div
                        class="bg-zinc-900 p-5 md:p-7 border-b-4 border-emerald-500 rounded-t-lg shadow-2xl flex flex-col justify-between">
                        <div>
                            <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Academics</p>
                            <h3 class="text-xl md:text-2xl font-bold mt-2 text-zinc-400">Add Material</h3>
                        </div>
                        <a href="/admin/resources/new"
                            class="mt-4 bg-zinc-800 border border-zinc-700 text-white text-[9px] font-bold uppercase tracking-widest py-2 px-3 rounded hover:bg-emerald-700 transition-all text-center">
                            UPLOAD DATA
                        </a>
                    </div>
                </div>

                <div class="bg-zinc-900 rounded-xl shadow-2xl border border-zinc-800 overflow-hidden">
                    <div class="p-5 md:p-8 border-b border-zinc-800 flex justify-between items-center">
                        <h4 class="text-xl md:text-2xl text-white italic">Recent Complaints</h4>
                        <a href="/admin/complaints"
                            class="text-red-600 text-[10px] font-bold hover:text-white uppercase tracking-widest font-sans transition-colors">View
                            All</a>
                    </div>



                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead
                                class="bg-zinc-950 text-zinc-300 text-[10px] uppercase font-bold tracking-[0.2em] font-sans">
                                <tr>
                                    <th class="p-5">Resident Name</th>
                                    <th class="p-5">Room</th>
                                    <th class="p-5">Category</th>
                                    <th class="p-5 text-right">Status</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm text-zinc-300 font-sans">
                                <% if(complaints.length> 0) { %>
                                    <% complaints.forEach(c=> { %>
                                        <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/40 transition cursor-pointer"
                                            onclick="window.location='/admin/complaints/<%= c._id %>'">
                                            <td class="p-5">
                                                <span class="font-bold text-white block">
                                                    <%= c.student ? c.student.name : 'Unknown' %>
                                                </span>
                                                <span class="text-[9px] text-zinc-600 uppercase">
                                                    Resident</span>
                                            </td>
                                            <td class="p-5 text-zinc-500 font-mono text-xs">
                                                <%= c.roomNumber %>
                                            </td>
                                            <td class="p-5 text-xs text-zinc-400">
                                                <%= c.category %>
                                            </td>
                                            <td class="p-5 text-right">
                                                <span
                                                    class="px-3 py-1 rounded-full text-[9px] font-bold uppercase tracking-tighter whitespace-nowrap 
                                                    <%= c.status === 'Pending' ? 'bg-red-900/20 text-red-500 border border-red-900/50' : 'bg-emerald-900/20 text-emerald-500 border border-emerald-900/50' %>">
                                                    <%= c.status %>
                                                </span>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="4"
                                                        class="p-16 text-center text-zinc-400 text-xs italic">
                                                        <i class="ri-inbox-archive-line text-3xl block mb-2"></i>
                                                        No recent complaints found in the digital register
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
            <script>
                function toggleAdminModal() {
                    const modal = document.getElementById('adminModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }

                function toggleResidentModal() {
                    const modal = document.getElementById('residentModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }

                function filterResidents() {
                    const input = document.getElementById('residentSearch').value.toUpperCase();
                    const rows = document.querySelectorAll('.resident-row');

                    rows.forEach(row => {
                        const text = row.innerText.toUpperCase();
                        row.style.display = text.includes(input) ? "" : "none";
                    });
                }
                function toggleSecurityModal() {
                    const modal = document.getElementById('securityModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }

                function toggleAnnouncementModal() {
                    const modal = document.getElementById('announcementModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }
            </script>

            <%- include('../partials/footer') %>