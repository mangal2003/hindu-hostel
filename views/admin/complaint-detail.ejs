<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>

            <main class="flex-grow bg-zinc-950 p-6 md:p-12 font-serif text-stone-50">
                <div class="max-w-3xl mx-auto">

                    <div class="flex justify-between items-center mb-10">
                        <a href="javascript:void(0)" onclick="history.back()"
                            class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2">
                            <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                            <span>Back</span>
                        </a>
                        <span class="text-[10px] font-sans font-bold tracking-[0.3em] text-zinc-600 uppercase">
                            Complaint ID: <span class="text-white">
                                <%= complaint._id.toString().slice(-6) %>
                            </span>
                        </span>
                    </div>

                    <div class="bg-zinc-900 rounded-2xl shadow-2xl border border-zinc-800 overflow-hidden">

                        <div
                            class="p-8 border-b border-zinc-800 bg-zinc-900/50 flex flex-col md:flex-row md:justify-between md:items-center gap-6">
                            <div class="flex-grow min-w-0">
                                <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight tracking-tighter">
                                    <%= complaint.subject %>
                                </h2>
                            </div>

                            <div class="flex-shrink-0 self-start md:self-center">
                                <% let statusStyle="bg-red-900/20 text-red-500 border-red-900/50" ;
                                    if(complaint.status==='In Progress' )
                                    statusStyle="bg-blue-900/20 text-blue-500 border-blue-900/50" ;
                                    if(complaint.status==='Resolved' )
                                    statusStyle="bg-emerald-900/20 text-emerald-500 border-emerald-900/50" ; %>
                                    <span
                                        class="<%= statusStyle %> px-5 py-2 rounded-full text-[10px] font-sans font-bold uppercase tracking-widest border shadow-lg">
                                        <%= complaint.status %>
                                    </span>
                            </div>
                        </div>

                        <div class="p-8 space-y-10">
                            <div
                                class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-zinc-950 p-6 rounded-xl border border-zinc-800/50">
                                <div class="min-w-0">
                                    <p
                                        class="text-[10px] font-sans font-bold text-zinc-600 uppercase mb-2 tracking-widest">
                                        Filing Resident</p>
                                    <p class="text-xl font-bold text-white leading-tight">
                                        <%= complaint.student.name %>
                                    </p>
                                    <p class="text-sm text-zinc-500 font-sans mt-1">
                                        <%= complaint.student.email %>
                                    </p>
                                </div>
                                <div class="min-w-0 md:border-l border-zinc-800 md:pl-8 flex flex-col justify-center">
                                    <p class="text-2xl font-bold text-red-600 tracking-tighter">Room <%=
                                            complaint.roomNumber %>
                                    </p>
                                    <p class="text-[10px] text-zinc-500 uppercase font-sans tracking-widest mt-1">
                                        Category: <span class="text-zinc-300">
                                            <%= complaint.category %>
                                        </span>
                                    </p>
                                </div>
                            </div>

                            <div>
                                <p class="text-[10px] font-sans font-bold text-zinc-600 uppercase mb-4 tracking-widest">
                                    Formal Statement</p>
                                <div
                                    class="text-zinc-300 text-lg leading-relaxed bg-zinc-950/50 border border-zinc-800 p-8 rounded-xl italic">
                                    "<%= complaint.description %>"
                                </div>
                            </div>

                            <hr class="border-zinc-800">

                            <div>
                                <p
                                    class="text-[10px] font-sans font-bold text-zinc-400 uppercase mb-6 tracking-widest text-center md:text-left">
                                    Admin Decision</p>
                                <form action="/admin/complaints/update-status" method="POST"
                                    class="flex flex-col sm:flex-row gap-4">
                                    <input type="hidden" name="complaintId" value="<%= complaint._id %>">

                                    <div class="relative flex-grow font-sans">
                                        <select name="status"
                                            class="w-full bg-zinc-950 border border-zinc-800 rounded-lg p-4 text-white focus:border-red-700 outline-none appearance-none cursor-pointer transition-all">
                                            <option value="Pending" <%=complaint.status==='Pending' ? 'selected' : '' %>
                                                >Mark as Pending</option>
                                            <option value="In Progress" <%=complaint.status==='In Progress' ? 'selected'
                                                : '' %>>Set to In Progress</option>
                                            <option value="Resolved" <%=complaint.status==='Resolved' ? 'selected' : ''
                                                %>>Mark as Resolved</option>
                                        </select>
                                        <div
                                            class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-zinc-500">
                                            <i class="ri-arrow-down-s-line"></i>
                                        </div>
                                    </div>

                                    <button type="submit"
                                        class="bg-red-700 hover:bg-white hover:text-black text-white font-sans font-bold px-10 py-4 rounded-lg transition-all tracking-[0.2em] text-[10px]">
                                        UPDATE
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="bg-zinc-950/80 p-5 border-t border-zinc-800 text-center font-sans">
                            <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-[0.3em]">
                                Log Entry Created: <span class="text-red-500">
                                    <%= complaint.createdAt.toLocaleString() %>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </main>

            <%- include('../partials/footer') %>